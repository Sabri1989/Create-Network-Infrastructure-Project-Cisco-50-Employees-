hostname Edge-Router
enable secret Cisco123

! === WAN Interface (Internet) ===
interface gigabitEthernet 0/0/0
 description WAN_to_ISP
 ip address dhcp
 ip nat outside
 no shutdown

! === LAN Interface to Core Switch ===
interface gigabitEthernet 0/0/1
 description LAN_to_Core_Switch
 ip address 192.168.0.1 255.255.255.252
 ip nat inside
 no shutdown

! === NAT Configuration ===
access-list 100 permit ip 192.168.10.0 0.0.0.63 any
access-list 100 permit ip 192.168.20.0 0.0.0.63 any
access-list 100 permit ip 192.168.30.0 0.0.0.31 any
access-list 100 permit ip 192.168.100.0 0.0.0.15 any
access-list 100 deny ip 192.168.40.0 0.0.0.31 any  ! Guest network - NO NAT

ip nat inside source list 100 interface gigabitEthernet 0/0/0 overload

! === Static Return Routes ===
ip route 192.168.10.0 255.255.255.192 192.168.0.2
ip route 192.168.10.0 255.255.255.192 192.168.0.3 2  ! Backup route
ip route 192.168.20.0 255.255.255.192 192.168.0.2
ip route 192.168.20.0 255.255.255.192 192.168.0.3 2
ip route 192.168.30.0 255.255.255.224 192.168.0.2
ip route 192.168.30.0 255.255.255.224 192.168.0.3 2
ip route 192.168.40.0 255.255.255.224 192.168.0.2
ip route 192.168.100.0 255.255.255.240 192.168.0.2
ip route 192.168.100.0 255.255.255.240 192.168.0.3 2

! === DHCP Server ===
ip dhcp excluded-address 192.168.10.1 192.168.10.10
ip dhcp pool IT_POOL
 network 192.168.10.0 255.255.255.192
 default-router 192.168.10.1
 dns-server 8.8.8.8 8.8.4.4
 lease 2

ip dhcp pool Sales_POOL
 network 192.168.20.0 255.255.255.192
 default-router 192.168.20.1
 dns-server 8.8.8.8 8.8.4.4

ip dhcp pool HR_POOL
 network 192.168.30.0 255.255.255.224
 default-router 192.168.30.1
 dns-server 8.8.8.8 8.8.4.4

! === Ingress Firewall ACL ===
access-list 101 deny ip 192.168.40.0 0.0.0.31 192.168.0.0 0.0.255.255
access-list 101 permit ip any any
interface gigabitEthernet 0/0/0
 ip access-group 101 in

! ==== SSH Management ====
ip domain-name company.local
crypto key generate rsa modulus 2048
username admin secret Cisco123
line vty 0 4
 transport input  ssh
 login local
line console 0
 logging synchronous
 exec-timeout 5 0

end
write memory
